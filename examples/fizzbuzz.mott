fnc kort() {
    xilit i: terah = 1
    cqachunna i <= 100 {
        nagah sanna i % 3 == 0 a, i % 5 == 0 a {
            yazde("FizzBuzz")
        } vusht nagah sanna i % 3 == 0 {
            yazde("Fizz")
        } vusht nagah sanna i % 5 == 0 {
            yazde("Buzz")
        } vusht {
            yazde("{i}")
        }
        i = i + 1
    }
}
