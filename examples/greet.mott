// Приветствие по имени — демонстрирует сравнение строк.

fnc greet(name: deshnash) {
    nagah sanna name == "Ruslan" {
        yazde("Salam, voqsha Ruslan!")
    } khi nagah sanna name == "Madina" {
        yazde("Salam, yisha Madina!")
    } khi {
        yazde("Salam, {name}!")
    }
}

fnc kort() {
    greet("Ruslan")
    greet("Madina")
    greet("Timur")
}
